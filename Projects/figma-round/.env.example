# Spotlight news — GNews (https://gnews.io) free tier.
# Copy this file to `.env.local` (git-ignored) and fill in your key.
#
#   cp .env.example .env.local
#
# Get a free key at https://gnews.io/register — no key means the Spotlight
# section renders the bundled mock data instead (no network request).
VITE_GNEWS_API_KEY=

# Optional overrides (defaults shown):
# VITE_GNEWS_CATEGORY=business
# VITE_GNEWS_LANG=en

# Force the mock data even when a key is present (handy for offline/demo):
# VITE_USE_MOCK_NEWS=true
